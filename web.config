<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <!-- 
      Windows Server + IIS 用設定ファイル
      
      【パターンA: 静的ホームページとして公開する場合】
      下のリライトルール（<rewrite>）は不要です。単純に tobita-girls-website-release.zip の「中身」を 
      C:\wwwroot\tobitashinchi-recruit.com の直下に展開してください。
      
      【パターンB: Node.js (Express) を本番で稼働させ、CMSでコラム追加を同期する場合】
      1. IISに「URL Rewrite」モジュールおよび「Application Request Routing (ARR)」がインストールされている必要があります。
      2. ARRの「Server Proxy Settings」で「Enable proxy」を有効にしてください。
      3. バックグラウンドで「npm run start」(ポート3000)を起動しておきます。
      4. 下記の書き換えルールによって、ポート80/443(IIS)へのアクセスが自動的にポート3000のNode.jsへ転送されます。
    -->
    <rewrite>
      <rules>
        <rule name="Reverse Proxy to Node.js" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:3000/{R:1}" />
        </rule>
      </rules>
    </rewrite>
    
    <!-- 静的ファイル(js, css, jpegなど)のMIMEタイプ定義の競合防止 -->
    <staticContent>
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <remove fileExtension=".webp" />
      <mimeMap fileExtension=".webp" mimeType="image/webp" />
    </staticContent>
  </system.webServer>
</configuration>
